{
  "expo": {
    "name": "Laju Gizi",
    "slug": "driver_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ikon-sppg.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    
    "splash": {
      "image": "./assets/ikon-sppg.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/ikon-sppg.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": false,
      "package": "com.elinakma.driver_app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/ikon-sppg.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Izin untuk melacak lokasi saat pengiriman berlangsung.",
          "android": {
            "foregroundService": {
              "title": "Laju Gizi sedang melacak lokasi",
              "body": "Aplikasi sedang berjalan di latar belakang untuk tracking pengiriman."
            }
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "35a3af08-bd2d-4c3a-a68b-2321c7b283da"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": false
    }
  }
}
